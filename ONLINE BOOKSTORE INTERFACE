<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Advanced Book Store</title>

<style>
body { font-family: Arial; margin:0; background:#f4f4f4; }

header {
  display:flex; justify-content:space-between;
  padding:15px; background:#222; color:white;
}

.container {
  display:grid;
  grid-template-columns:repeat(2,1fr);
  gap:20px; padding:20px;
}

.card {
  background:white; padding:10px;
  border-radius:10px; text-align:center;
}

.card img {
  width:100%; height:200px; object-fit:cover;
}

button {
  padding:8px; margin:5px;
  border:none; border-radius:5px;
  cursor:pointer;
}

.cart-btn { background:green; color:white; }
.wish-btn { background:pink; }

.pagination {
  text-align:center;
  margin:20px;
}
</style>
</head>

<body>

<header>
  <h2>📚 Smart Book Store</h2>
  <div>
    ❤️ <span id="wish-count">0</span>
    🛒 <span id="cart-count">0</span>
  </div>
</header>

<div class="container" id="book-list"></div>

<div class="pagination">
  <button onclick="prevPage()">⬅ Prev</button>
  <span id="page-num">1</span>
  <button onclick="nextPage()">Next ➡</button>
</div>

<script>
const books = [
  {id:1,name:"The Alchemist",price:350,img:"https://covers.openlibrary.org/b/id/10523338-L.jpg"},
  {id:2,name:"Rich Dad Poor Dad",price:400,img:"https://covers.openlibrary.org/b/id/8225261-L.jpg"},
  {id:3,name:"Atomic Habits",price:500,img:"https://covers.openlibrary.org/b/id/11153207-L.jpg"},
  {id:4,name:"Think and Grow Rich",price:300,img:"https://covers.openlibrary.org/b/id/8231856-L.jpg"},
  {id:5,name:"Harry Potter",price:600,img:"https://covers.openlibrary.org/b/id/7984916-L.jpg"},
  {id:6,name:"Power of Habit",price:420,img:"https://covers.openlibrary.org/b/id/8231996-L.jpg"},
  {id:7,name:"Deep Work",price:450,img:"https://covers.openlibrary.org/b/id/8370220-L.jpg"},
  {id:8,name:"Ikigai",price:350,img:"https://covers.openlibrary.org/b/id/9259252-L.jpg"},
  {id:9,name:"Start With Why",price:370,img:"https://covers.openlibrary.org/b/id/8235116-L.jpg"},
  {id:10,name:"Zero to One",price:390,img:"https://covers.openlibrary.org/b/id/8375425-L.jpg"},
  {id:11,name:"The 5 AM Club",price:410,img:"https://covers.openlibrary.org/b/id/9259253-L.jpg"},
  {id:12,name:"Think Like a Monk",price:420,img:"https://covers.openlibrary.org/b/id/11192533-L.jpg"},
  {id:13,name:"Do Epic Shit",price:300,img:"https://covers.openlibrary.org/b/id/11192534-L.jpg"},
  {id:14,name:"You Can Win",price:280,img:"https://covers.openlibrary.org/b/id/11192535-L.jpg"},
  {id:15,name:"Psychology of Money",price:450,img:"https://covers.openlibrary.org/b/id/11192536-L.jpg"},
  {id:16,name:"Can't Hurt Me",price:480,img:"https://covers.openlibrary.org/b/id/11192537-L.jpg"},
  {id:17,name:"The Monk Who Sold Ferrari",price:350,img:"https://covers.openlibrary.org/b/id/8235117-L.jpg"},
  {id:18,name:"Wings of Fire",price:300,img:"https://covers.openlibrary.org/b/id/8235118-L.jpg"},
  {id:19,name:"The Secret",price:330,img:"https://covers.openlibrary.org/b/id/8235119-L.jpg"},
  {id:20,name:"Attitude is Everything",price:310,img:"https://covers.openlibrary.org/b/id/8235120-L.jpg"}
];

let cart = JSON.parse(localStorage.getItem("cart")) || [];
let wishlist = JSON.parse(localStorage.getItem("wishlist")) || [];

let currentPage = 1;
const perPage = 2;

function displayBooks(){
  const list = document.getElementById("book-list");
  list.innerHTML = "";

  let start = (currentPage-1)*perPage;
  let pageBooks = books.slice(start, start+perPage);

  pageBooks.forEach(book=>{
    let div = document.createElement("div");
    div.className="card";

    div.innerHTML = `
      <img src="${book.img}">
      <h3>${book.name}</h3>
      <p>₹${book.price}</p>
      <button class="cart-btn" onclick="addCart(${book.id})">Add Cart</button>
      <button class="wish-btn" onclick="addWish(${book.id})">Wishlist</button>
    `;

    list.appendChild(div);
  });

  document.getElementById("page-num").innerText = currentPage;
}

function nextPage(){
  if(currentPage < books.length/perPage){
    currentPage++;
    displayBooks();
  }
}

function prevPage(){
  if(currentPage > 1){
    currentPage--;
    displayBooks();
  }
}

function addCart(id){
  cart.push(id);
  localStorage.setItem("cart", JSON.stringify(cart));
  updateCount();
}

function addWish(id){
  wishlist.push(id);
  localStorage.setItem("wishlist", JSON.stringify(wishlist));
  updateCount();
}

function updateCount(){
  document.getElementById("cart-count").innerText = cart.length;
  document.getElementById("wish-count").innerText = wishlist.length;
}

updateCount();
displayBooks();
</script>

</body>
</html>
